# Discord OAuth2 credentials - get from https://discord.com/developers/applications
DISCORD_CLIENT_ID=YOUR_DISCORD_CLIENT_ID
DISCORD_CLIENT_SECRET=YOUR_DISCORD_CLIENT_SECRET
DISCORD_REDIRECT_URI=http://localhost:3001/auth/discord/callback

# Session secret - change to a long random string in production
SESSION_SECRET=change_this_to_a_long_random_string_in_production

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Owner Discord User ID
OWNER_ID=1304126568817229875

# Server port
PORT=3001
